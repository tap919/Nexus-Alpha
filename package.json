{
  "name": "nexus-alpha",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:all": "concurrently -k -n \"vite,api\" -c \"cyan,green\" \"npm run dev\" \"npm run server\"",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "tsc --project electron/tsconfig.json && npm run build && electron-builder",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "playwright test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "ci": "npm run typecheck && npm run build && npm run test:e2e",
    "server": "tsx src/server/index.ts",
    "mcp": "tsx src/server/mcp.ts",
    "infra": "tsx src/services/local-infra.ts"
  },
  "dependencies": {
    "@biomejs/biome": "^2.4.13",
    "@google/genai": "^1.29.0",
    "@hono/zod-openapi": "^1.3.0",
    "@hookform/resolvers": "^5.2.2",
    "@langchain/community": "^1.1.27",
    "@langchain/core": "^1.1.42",
    "@langchain/openai": "^1.4.5",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@monaco-editor/react": "^4.7.0",
    "@qdrant/js-client-rest": "^1.17.0",
    "@supabase/postgrest-js": "^2.105.1",
    "@supabase/supabase-js": "^2.39.0",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.100.6",
    "@temporalio/client": "^1.16.1",
    "@temporalio/worker": "^1.16.1",
    "@temporalio/workflow": "^1.16.1",
    "@vitejs/plugin-react": "^5.0.4",
    "@xenova/transformers": "^2.17.2",
    "bullmq": "^5.76.4",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "hono": "^4.12.15",
    "knip": "^6.9.0",
    "langchain": "^1.3.5",
    "lightweight-charts": "^5.2.0",
    "lucide-react": "^0.546.0",
    "microdiff": "^1.5.0",
    "motion": "^12.23.24",
    "opossum": "^9.0.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.74.0",
    "react-is": "^19.2.5",
    "react-lightweight-charts": "^0.1.0",
    "react-router-dom": "^6.28.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "ws": "^8.18.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "y-indexeddb": "^9.0.12",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.30",
    "zod": "^4.3.6",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/express": "^4.17.21",
    "@types/node": "^25.6.0",
    "@types/ws": "^8.5.10",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^41.4.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-node-polyfills": "^0.26.0"
  },
  "build": {
    "appId": "com.nexus.alpha",
    "productName": "Nexus Alpha",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    }
  }
}
