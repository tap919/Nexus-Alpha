# ============================================================
# Nexus Alpha - Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# Required: Google Gemini API key (get from https://ai.google.dev)
GEMINI_API_KEY=

# Optional: GitHub Personal Access Token (repo + workflow scopes)
# Required for live repo data, workflow triggers, security advisories
GITHUB_TOKEN=

# Optional: OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Optional: DeepSeek (https://platform.deepseek.com)
DEEPSEEK_API_KEY=

# Optional: OpenCode / Gemini alias
OPENCODE_API_KEY=

# Optional: Supabase Auth (https://supabase.com/dashboard/project/_/settings/api)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Server ports
PORT=3000
WS_PORT=3001

# App URL
APP_URL=http://localhost:3000

# Optional: Webhook secret for verifying incoming payloads
# WEBHOOK_SECRET=your_webhook_secret_here
