# ============================================================
# Nexus Alpha - Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# Required: Google Gemini API key (get from https://ai.google.dev)
GEMINI_API_KEY=

# Optional: GitHub Personal Access Token (repo + workflow scopes)
# Required for live repo data, workflow triggers, security advisories
GITHUB_TOKEN=

# Optional: OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Optional: DeepSeek (https://platform.deepseek.com)
DEEPSEEK_API_KEY=

# Optional: OpenCode / Gemini alias
OPENCODE_API_KEY=

# Optional: Ollama local LLM (no API key needed, just the endpoint)
# Default: http://localhost:11434
OLLAMA_HOST=http://localhost:11434

# Optional: Supabase Auth (https://supabase.com/dashboard/project/_/settings/api)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=

# Optional: Security & Auth
NEXUS_API_KEY=
NEXUS_AUTH_BYPASS=false

# Server ports
PORT=3000
# WebSocket upgrades are served on PORT at /ws.
WS_PORT=3001

# App URL
APP_URL=http://localhost:3000

# Networking & Limits
CORS_ORIGINS=http://localhost:3000
MAX_WS_CLIENTS=200

# Optional: Webhook secret for verifying incoming payloads
# WEBHOOK_SECRET=your_webhook_secret_here
