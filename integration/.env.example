# ============================================
# NEXUS ALPHA - COMPLETE ENVIRONMENT CONFIG
# ============================================

# ============================================
# CORE API KEYS (REQUIRED)
# ============================================

# Claude/Anthropic - For agent models
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# OpenAI - For embeddings & RAG
OPENAI_API_KEY=sk-your-openai-key-here

# GitHub - For repository operations
GITHUB_TOKEN=ghp_your_github_token_here

# ============================================
# DATABASE
# ============================================

POSTGRES_PASSWORD=nexus_secure_dev_password_123
DATABASE_URL=postgresql://nexus:nexus_secure_dev_password_123@postgres:5432/nexus_alpha

# ============================================
# VECTOR DATABASE (Qdrant)
# ============================================

QDRANT_API_KEY=your-qdrant-api-key-optional
QDRANT_URL=http://localhost:6333

# ============================================
# MEMORY LAYER (Mem0)
# ============================================

# Get free key at https://mem0.ai
MEM0_API_KEY=your-mem0-api-key

# ============================================
# WEB SEARCH (Choose at least one)
# ============================================

# Firecrawl - https://firecrawl.dev
FIRECRAWL_API_KEY=your-firecrawl-api-key

# Tavily - https://tavily.com
TAVILY_API_KEY=your-tavily-api-key

# Exa - https://exa.ai
EXA_API_KEY=your-exa-api-key

# ============================================
# OBSERVABILITY (Langfuse)
# ============================================

# Get keys at https://langfuse.com
LANGFUSE_PUBLIC_KEY=your-public-key
LANGFUSE_SECRET_KEY=your-secret-key
NEXTAUTH_SECRET=super-secret-random-string-change-me
LANGFUSE_SALT=another-random-string-for-hashing

# ============================================
# OPTIONAL: SUPABASE
# ============================================

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# ============================================
# OPTIONAL: AUTH
# ============================================

# Clerk - https://clerk.com
CLERK_PUBLISHABLE_KEY=pk_test_your-key
CLERK_SECRET_KEY=sk_test_your-key

# ============================================
# OPTIONAL: CACHE (Redis)
# ============================================

REDIS_URL=redis://localhost:6379

# Upstash - https://upstash.com
UPSTASH_REDIS_REST_URL=https://your-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ============================================
# OPTIONAL: MONITORING
# ============================================

# Prometheus/Grafana (if using monitoring stack)
PROMETHEUS_URL=http://prometheus:9090
GRAFANA_URL=http://grafana:3000
GRAFANA_PASSWORD=admin

# ============================================
# OPTIONAL: ADDITIONAL SERVICES
# ============================================

# Neo4j - For GraphRAG (optional)
NEO4J_PASSWORD=neo4j_dev_password

# Slack MCP (optional)
SLACK_BOT_TOKEN=xoxb-your-slack-token
SLACK_TEAM_ID=your-team-id

# Notion MCP (optional)
NOTION_API_KEY=secret_your-notion-key

# ============================================
# DEVELOPMENT SETTINGS
# ============================================

NODE_ENV=development
LOG_LEVEL=debug
DEBUG=true